# ============================================================
#  OKXB  —  环境变量模板
#  用法: 复制本文件为 .env, 填入你【轮换后】的新密钥。
#  .env 已被 .gitignore 忽略, 永远不要提交、不要贴给任何人。
# ============================================================

# ---- 运行模式 ----
# demo = 模拟盘 (x-simulated-trading: 1), live = 实盘
# 第一阶段强制 demo。切 live 前必须通过回测 + 模拟盘验证。
# 注意: demo 需要在 OKX「Demo Trading」区单独创建的 API key, 实盘 key 在 demo 无效。
OKXB_MODE=demo

# ---- 区域路由 (重要) ----
# 账户所属地区决定 API 域名, 用错会鉴权/路由失败:
#   global -> www.okx.com   (非美非欧)
#   us     -> us.okx.com    (美/澳; 注意: 美国实体仅现货, 无永续/股票永续)
#   eea    -> eea.okx.com   (欧盟/EEA)
# 禁止用 VPN 绕过地区限制 (违反 OKX 条款, 风险冻结/没收)。
OKX_REGION=global

# ---- OKX 模拟盘密钥 (备注名 Virtual) ----
OKX_DEMO_API_KEY=
OKX_DEMO_SECRET_KEY=
OKX_DEMO_PASSPHRASE=

# ---- OKX 实盘密钥 (备注名 APP) ----
# 仅在 OKXB_MODE=live 时使用。务必: 关闭提现权限 + 绑定 IP 白名单。
OKX_LIVE_API_KEY=
OKX_LIVE_SECRET_KEY=
OKX_LIVE_PASSPHRASE=

# ---- 外部数据 / AI 事件源 ----
# SEC EDGAR 无需 key, 但要求 User-Agent 写真实联系邮箱 (合规要求)。
EDGAR_USER_AGENT=OKXB research svvwh12@gmail.com

# Finnhub 免费档 (财报日历 + 公司/市场新闻): https://finnhub.io/register
FINNHUB_API_KEY=

# 加密新闻 (喂给 AI选品 / 单标的分析, 每条带来源+时间戳供核对; fail-closed 留空即休眠)
# CryptoPanic token (免费档可申请): https://cryptopanic.com/developers/api/
CRYPTOPANIC_API_KEY=
# 加密新闻 RSS (无需 key; 默认 CoinDesk 一手编辑标题; 可换 The Block 等)
CRYPTO_NEWS_RSS_URL=https://www.coindesk.com/arc/outboundfeeds/rss/

# 经济日历 (CPI/NFP/FOMC 排定时间, 用于"别在数据公布前盲目开仓"的风险提示, 非预测)
# TradingEconomics: https://tradingeconomics.com/api  (留空则该功能休眠)
TRADING_ECONOMICS_API_KEY=

# CoinGecko 行情/大盘数据 (非新闻): 全球加密市值/BTC占比/热搜趋势, 喂给 AI 选品作大盘背景。
# 免费 demo key: https://www.coingecko.com/en/developers/dashboard  (留空即休眠)
COINGECKO_API_KEY=

# 研究数据保存目录 (IMR 15/30min 与 AI 前向验证 的工件存这里; 留空=程序同级 data/)
# 也可在 GUI『多周期研究』页用『📂 选择目录』设置。
RESEARCH_DATA_DIR=

# AI 事件分类 (新闻/公告 -> 结构化风险标签; 提供商无关, 留空则用免费规则)
# provider: rule(免费规则) / deepseek / openai_compatible / claude
AI_PROVIDER=rule
AI_API_KEY=
AI_BASE_URL=https://api.deepseek.com
# DeepSeek 官方模型名 (写错会调用空返回 -> 选品/分析为空):
#   deepseek-chat     = 便宜快 (结构化/选品用这个最稳)
#   deepseek-reasoner = 更强、会推理 (自由文本深度分析; 结构化 JSON 偶尔不稳)
AI_MODEL_SIMPLE=deepseek-chat
AI_MODEL_HARD=deepseek-reasoner
# 选型策略: auto(自由文本新闻+高危8-K用pro, 其余flash) / flash(总用便宜) / pro(总用强)
# 每次调用都会在日志里打印实际用了哪个模型, 不会"不知道调哪个"。
AI_TIER_POLICY=auto
# 其他提供商示例:
#   OpenAI:   AI_PROVIDER=openai_compatible  AI_BASE_URL=https://api.openai.com/v1  AI_MODEL_SIMPLE=gpt-4o-mini
#   Claude:   AI_PROVIDER=claude  AI_API_KEY=sk-ant-...  AI_MODEL_SIMPLE=claude-haiku-4-5  (需 pip install anthropic)

# ---- 告警 (可选, 强烈建议) ----
# Telegram bot, 用于推送成交/风控/熔断告警与远程急停。
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
